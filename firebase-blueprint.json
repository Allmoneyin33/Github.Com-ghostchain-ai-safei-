{
  "entities": {
    "AgentTask": {
      "title": "Agent Task",
      "description": "A scheduled or queued task for an AI agent to execute.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string", "description": "ID of the target agent" },
        "userId": { "type": "string", "description": "UID of the owner" },
        "type": { "type": "string", "description": "Task classification" },
        "priority": { "type": "integer", "description": "Priority level (smaller = higher)" },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed", "failed"] },
        "payload": { "type": "object", "description": "Input arguments for the task" },
        "result": { "type": "object", "description": "Execution output" },
        "error": { "type": "string", "description": "Error details if failed" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "userId", "type", "status", "createdAt", "updatedAt"]
    },
    "UserStats": {
      "title": "User Stats",
      "description": "Aggregate statistics for a specific user.",
      "type": "object",
      "properties": {
        "totalProfit": { "type": "number" },
        "totalSpend": { "type": "number" },
        "lastActive": { "type": "string", "format": "date-time" }
      }
    },
    "UserCredits": {
      "title": "User Credits",
      "description": "Financial credits for agent execution.",
      "type": "object",
      "properties": {
        "credits": { "type": "number" },
        "userId": { "type": "string" }
      }
    },
    "Settlement": {
      "title": "Settlement",
      "description": "A record of a financial transaction or bridge settlement.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "to": { "type": "string" },
        "status": { "type": "string" },
        "type": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      }
    },
    "SovereignAgent": {
      "title": "Sovereign Agent",
      "description": "A self-evolving neural agent synthesized in the Nexus.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "class": { "type": "string" },
        "iq": { "type": "number" },
        "potency": { "type": "number" },
        "description": { "type": "string" },
        "specialty": { "type": "string" },
        "resonance": { "type": "number" },
        "ascensionLevel": { "type": "number" },
        "lore": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "evolving", "synthesizing", "standby"] },
        "hash": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "class", "status", "hash"]
    }
  },
  "firestore": {
    "agent_tasks": {
      "schema": "AgentTask",
      "description": "Queue for autonomous agent operations."
    },
    "user_stats": {
      "schema": "UserStats",
      "description": "User profitability and performance metrics."
    },
    "user_credits": {
      "schema": "UserCredits",
      "description": "User balance for bot operations."
    },
    "settlements": {
      "schema": "Settlement",
      "description": "Immutable ledger of all financial movements."
    },
    "sovereign_agents": {
      "schema": "SovereignAgent",
      "description": "Registry of all synthesized agents in the ecosystem."
    }
  }
}
