{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and financial integration details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "stripeCustomerId": { "type": "string" },
        "plaidAccessToken": { "type": "string" },
        "dwollaCustomerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Agent": {
      "title": "AI Agent",
      "description": "Autonomous financial AI agent with self-repair capabilities.",
      "type": "object",
      "properties": {
        "agentId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "paused", "repairing", "innovating"] },
        "ownerUid": { "type": "string" },
        "lastSignal": { "type": "string" },
        "reputation": { "type": "number" },
        "reputationHistory": { "type": "array", "items": { "type": "number" } },
        "capabilities": { "type": "array", "items": { "type": "string" } },
        "cognitiveGrowth": { "type": "number" },
        "healthScore": { "type": "number" },
        "nextStepRecommendations": { "type": "array", "items": { "type": "string" } },
        "selfInstallationStatus": { "type": "string", "enum": ["idle", "installing", "completed", "failed"] },
        "autoRepairLogs": { "type": "array", "items": { "type": "string" } },
        "innovationLevel": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "name", "status", "ownerUid"]
    },
    "Vault": {
      "title": "Vault",
      "description": "Central balance engine for multi-platform routing.",
      "type": "object",
      "properties": {
        "vaultId": { "type": "string" },
        "ownerUid": { "type": "string" },
        "balance": { "type": "number" },
        "currency": { "type": "string", "enum": ["USD", "ETH", "BTC"] },
        "platform": { "type": "string", "enum": ["stripe", "plaid", "dwolla", "blockchain"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["vaultId", "ownerUid", "balance", "currency"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record.",
      "type": "object",
      "properties": {
        "txId": { "type": "string" },
        "type": { "type": "string", "enum": ["payment", "transfer", "withdrawal", "deposit"] },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "fromUid": { "type": "string" },
        "toUid": { "type": "string" },
        "platform": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["txId", "type", "amount", "status", "fromUid"]
    },
    "Checkpoint": {
      "title": "Checkpoint",
      "description": "AI decision log for validation.",
      "type": "object",
      "properties": {
        "checkpointId": { "type": "string" },
        "agentId": { "type": "string" },
        "decision": { "type": "string" },
        "reasoning": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["checkpointId", "agentId", "decision", "timestamp"]
    },
    "AiBinding": {
      "title": "AI Binding",
      "description": "Unified AI response log (Gemini + OpenAI).",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "prompt": { "type": "string" },
        "gemini": { "type": "string" },
        "openai": { "type": "string" }
      },
      "required": ["timestamp", "prompt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/agents/{agentId}": {
      "schema": "Agent",
      "description": "AI agents registry."
    },
    "/vaults/{vaultId}": {
      "schema": "Vault",
      "description": "Financial vaults."
    },
    "/transactions/{txId}": {
      "schema": "Transaction",
      "description": "Transaction history."
    },
    "/checkpoints/{checkpointId}": {
      "schema": "Checkpoint",
      "description": "AI decision checkpoints."
    },
    "/ai_bindings/{txId}": {
      "schema": "AiBinding",
      "description": "Unified AI response logs."
    }
  }
}
