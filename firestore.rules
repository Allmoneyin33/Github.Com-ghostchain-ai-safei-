rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    
    function isValidAgentTask(data) {
      return data.keys().hasAll(['agentId', 'userId', 'type', 'status', 'createdAt', 'updatedAt']) &&
             data.agentId is string && data.agentId.size() <= 64 &&
             data.userId == request.auth.uid &&
             data.type is string && data.type.size() <= 32 &&
             data.status in ['pending', 'in-progress', 'completed', 'failed'] &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidUserStats(data) {
      return data.keys().hasAll(['totalProfit', 'totalSpend', 'lastActive']) &&
             data.totalProfit is number &&
             data.totalSpend is number &&
             data.lastActive == request.time;
    }

    function isValidUserCredits(data) {
      return data.keys().hasAll(['credits', 'userId']) &&
             data.credits is number &&
             data.userId == request.auth.uid;
    }

    // 3. Collection Rules

    match /agent_tasks/{taskId} {
      allow create: if isSignedIn() && 
                    isValidId(taskId) && 
                    isValidAgentTask(incoming()) &&
                    incoming().keys().size() <= 12; // Allow small payload/result variance

      allow update: if isSignedIn() && 
                    isOwner(existing().userId) &&
                    (
                      // Action: Status Update
                      (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'result', 'error']) &&
                       incoming().status in ['in-progress', 'completed', 'failed'] &&
                       incoming().updatedAt == request.time) ||
                      // Action: Reprioritization
                      (incoming().diff(existing()).affectedKeys().hasOnly(['priority', 'updatedAt']) &&
                       incoming().updatedAt == request.time)
                    );

      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /user_stats/{userId} {
      allow get: if isOwner(userId);
      // Stats are typically updated via server or very specific client updates
      allow create: if isOwner(userId) && isValidUserStats(incoming());
      allow update: if isOwner(userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['totalProfit', 'totalSpend', 'lastActive']) &&
                    incoming().lastActive == request.time;
    }

    match /user_credits/{userId} {
      allow get: if isOwner(userId);
      // Strictly prevent client from adding credits directly without a payment provider proof (stubbed here)
      allow create: if isOwner(userId) && isValidUserCredits(incoming());
      allow update: if isOwner(userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['credits', 'userId']) &&
                    existing().credits <= incoming().credits; // Basic guard: only allow increase if coupled with transaction logic (better handled server-side)
    }

    match /settlements/{settlementId} {
      allow create: if isSignedIn() && 
                    isValidId(settlementId) && 
                    incoming().userId == request.auth.uid &&
                    incoming().timestamp == request.time;
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    match /sovereign_agents/{agentId} {
      allow create: if isSignedIn() && 
                    isValidId(agentId) && 
                    incoming().userId == request.auth.uid &&
                    incoming().createdAt == request.time;
      
      allow update: if isOwner(existing().userId) && (
        // Action: Resonance Shift
        (incoming().diff(existing()).affectedKeys().hasOnly(['resonance', 'ascensionLevel', 'status', 'lore']) &&
         incoming().status in ['active', 'evolving', 'synthesizing', 'standby']) ||
        // Action: Metadata Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description']))
      );

      allow get: if true; // Public agent profiles
      allow list: if true;
    }

    // Sovereign Node Management
    match /sovereign_nodes/{nodeId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == resource.data.userId || !exists(/databases/$(database)/documents/sovereign_nodes/$(nodeId)));
    }
  }
}
